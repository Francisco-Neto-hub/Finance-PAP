<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="Finance.App.Views.MainPage"
             Title="Dashboard"
             Shell.NavBarIsVisible="False" 
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" Padding="20,10" ColumnDefinitions="*, Auto">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="Bem-vindo," TextColor="Gray" FontSize="14"/>
                <Label Text="O teu Resumo" TextColor="White" FontSize="20" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="Sair"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="#33FF1744"
                    TextColor="#FF1744"
                    CornerRadius="10"
                    HeightRequest="40"
                    FontAttributes="Bold"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <Border BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 15" Padding="20" StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="5">
                        <Label Text="SALDO DISPONÍVEL" TextColor="#A0A0A0" CharacterSpacing="1" FontSize="11" FontAttributes="Bold"/>
                        <Label Text="{Binding SaldoTotal, StringFormat='{0:N2} €'}" 
                               TextColor="White" FontSize="36" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Distribuição de Gastos" TextColor="White" FontAttributes="Bold" FontSize="16" Margin="5,0"/>
                <Border BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 15" HeightRequest="260" Padding="10" StrokeThickness="0">
                    <chart:ChartView Chart="{Binding SpendingChart}" 
                                     HeightRequest="240"
                                     HorizontalOptions="Fill" 
                                     VerticalOptions="Center" />
                </Border>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Últimos Movimentos" TextColor="White" FontAttributes="Bold" FontSize="16"/>
                    <Label Grid.Column="1" Text="Ver tudo" TextColor="#2979FF" FontSize="12" VerticalOptions="Center"/>
                </Grid>

                <CollectionView ItemsSource="{Binding Transacoes}" Margin="0,0,0,20">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 10" Margin="0,5" Padding="15" StrokeThickness="0">
                                <Grid ColumnDefinitions="40, *, Auto">
                                    <Ellipse Grid.Column="0" WidthRequest="35" HeightRequest="35" Fill="#2A2A2A"/>
                                    <Label Grid.Column="0" Text="💸" HorizontalOptions="Center" VerticalOptions="Center"/>

                                    <VerticalStackLayout Grid.Column="1" Margin="10,0">
                                        <Label Text="{Binding NomeTransacao}" TextColor="White" FontAttributes="Bold" MaxLines="1"/>
                                        <Label Text="{Binding DataTransacao, StringFormat='{0:dd MMM yyyy}'}" TextColor="Gray" FontSize="11"/>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" 
                                           Text="{Binding ValorTransacao, StringFormat='{0:N2} €'}" 
                                           TextColor="{Binding ValorTransacao, Converter={StaticResource ValorColorConverter}}" 
                                           VerticalOptions="Center" 
                                           FontAttributes="Bold"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>