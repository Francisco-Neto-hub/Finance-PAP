<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Finance.App.ViewModels"
             x:Class="Finance.App.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="#121212"
             Title="Criar Conta">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

        <Image Source="logo_financepgn.png" HeightRequest="100" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Label Text="Registe os seus dados" TextColor="White" FontSize="20" HorizontalOptions="Center" FontAttributes="Bold"/>

        <Border Stroke="#333" Background="#1E1E1E" StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Nome Completo" Text="{Binding Nome}" PlaceholderColor="#888" TextColor="White"/>
        </Border>

        <Border Stroke="#333" Background="#1E1E1E" StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" PlaceholderColor="#888" TextColor="White"/>
        </Border>

        <Border Stroke="#333" Background="#1E1E1E" StrokeShape="RoundRectangle 10" Padding="10,0">
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" PlaceholderColor="#888" TextColor="White"/>
        </Border>

        <Button Text="REGISTAR" 
                Command="{Binding RegisterCommand}"
                BackgroundColor="#00C2FF" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="50"
                Margin="0,10,0,0"/>

        <Button Text="Já tenho conta? Voltar ao Login" 
                Command="{Binding VoltarLoginCommand}"
                BackgroundColor="Transparent" 
                TextColor="#888" 
                FontSize="13"/>

        <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#00C2FF" HorizontalOptions="Center"/>

    </VerticalStackLayout>
</ContentPage>