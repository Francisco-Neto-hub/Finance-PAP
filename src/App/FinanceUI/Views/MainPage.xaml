<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FinanceUI.Models"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="FinanceUI.MainPage"
             BackgroundColor="#0F1115">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sair"
                     Clicked="AoClicarSair"
                     Priority="0" />
    </ContentPage.ToolbarItems>

    <!-- GRID PRINCIPAL -->
    <Grid ColumnDefinitions="280,*"
          RowDefinitions="Auto,*">

        <!-- LADO ESQUERDO VAZIO -->
        <Grid Grid.RowSpan="2"
              Grid.Column="0"
              BackgroundColor="#070B10" />

        <!-- CONTEÚDO -->
        <ScrollView Grid.Column="1"
                    Grid.RowSpan="2"
                    Orientation="Vertical">

            <Grid Padding="25,20,25,25"
                  MaximumWidthRequest="1250"
                  HorizontalOptions="Center">

                <VerticalStackLayout Spacing="22">

                    <!-- LOGO -->
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="5">

                        <Image Source="applogo.png"
                               HeightRequest="60"
                               Aspect="AspectFit"
                               HorizontalOptions="Center" />

                        <Label Text="Dashboard"
                               TextColor="White"
                               FontSize="24"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                    </VerticalStackLayout>

                    <!-- CARDS -->
                    <Grid ColumnDefinitions="2*,*,*"
      ColumnSpacing="16">

                        <!-- SALDO -->
                        <Border Grid.Column="0"
            BackgroundColor="#2952D1"
            Padding="22,16"
            StrokeThickness="0"
            HeightRequest="150"
            StrokeShape="RoundRectangle 22">

                            <VerticalStackLayout Spacing="6"
                             VerticalOptions="Center">

                                <Label Text="Saldo Total"
                   TextColor="#DCE7FF"
                   FontSize="14" />

                                <Label x:Name="LblSaldoTotal"
                   Text="0.00 €"
                   TextColor="White"
                   FontSize="28"
                   FontAttributes="Bold" />

                                <Label Text="Atualizado agora"
                   TextColor="#C8D7FF"
                   FontSize="11" />

                            </VerticalStackLayout>

                        </Border>

                        <!-- RECEITAS -->
                        <Border Grid.Column="1"
            BackgroundColor="#101821"
            Stroke="#16A34A"
            StrokeThickness="1.3"
            Padding="16"
            HeightRequest="150"
            StrokeShape="RoundRectangle 22">

                            <VerticalStackLayout VerticalOptions="Center"
                             Spacing="6">

                                <Label Text="Receitas"
                   FontSize="13"
                   TextColor="#7EE2A8" />

                                <Label x:Name="LblReceitas"
                   Text="0.00 €"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#22C55E" />

                            </VerticalStackLayout>

                        </Border>

                        <!-- DESPESAS -->
                        <Border Grid.Column="2"
            BackgroundColor="#101821"
            Stroke="#DC2626"
            StrokeThickness="1.3"
            Padding="16"
            HeightRequest="150"
            StrokeShape="RoundRectangle 22">

                            <VerticalStackLayout VerticalOptions="Center"
                             Spacing="6">

                                <Label Text="Despesas"
                   FontSize="13"
                   TextColor="#FFB0B0" />

                                <Label x:Name="LblDespesas"
                   Text="0.00 €"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#FF4D4D" />

                            </VerticalStackLayout>

                        </Border>

                    </Grid>

                    <!-- CONTAS + GRÁFICO -->
                    <Grid ColumnDefinitions="1*,1.4*"
                          ColumnSpacing="18">

                        <!-- CONTAS -->
                        <Border Grid.Column="0"
                                BackgroundColor="#121923"
                                Padding="20"
                                Stroke="#1E293B"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 22">

                            <VerticalStackLayout Spacing="16">

                                <Label Text="As minhas Contas"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <CollectionView x:Name="ListaContas"
                                                HeightRequest="260">

                                    <CollectionView.ItemTemplate>

                                        <DataTemplate x:DataType="models:ContaDTO">

                                            <Border BackgroundColor="#1A2330"
                                                    Padding="16"
                                                    Margin="0,0,0,10"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 16">

                                                <Grid ColumnDefinitions="*,Auto">

                                                    <VerticalStackLayout Spacing="4">

                                                        <Label Text="{Binding NomeConta}"
                                                               TextColor="#AAB7C7"
                                                               FontSize="13" />

                                                        <Label Text="{Binding MontanteFormatado}"
                                                               TextColor="White"
                                                               FontSize="22"
                                                               FontAttributes="Bold" />

                                                    </VerticalStackLayout>

                                                    <Frame Grid.Column="1"
                                                           HeightRequest="40"
                                                           WidthRequest="40"
                                                           CornerRadius="20"
                                                           BackgroundColor="#2952D1"
                                                           BorderColor="Transparent"
                                                           Padding="0"
                                                           VerticalOptions="Center">

                                                        <Label Text="€"
                                                               TextColor="White"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"
                                                               FontAttributes="Bold" />

                                                    </Frame>

                                                </Grid>

                                            </Border>

                                        </DataTemplate>

                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </VerticalStackLayout>

                        </Border>

                        <!-- GRÁFICO -->
                        <Border Grid.Column="1"
                                BackgroundColor="#121923"
                                Padding="20"
                                Stroke="#1E293B"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 22">

                            <VerticalStackLayout Spacing="16">

                                <Label Text="Despesas por Categoria"
                                       TextColor="White"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <micro:ChartView x:Name="ChartDashboard"
                                                  HeightRequest="260"
                                                  BackgroundColor="Transparent" />

                            </VerticalStackLayout>

                        </Border>

                    </Grid>

                    <!-- TRANSAÇÕES -->
                    <Border BackgroundColor="#121923"
                            Padding="20"
                            Stroke="#1E293B"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 22">

                        <VerticalStackLayout Spacing="18">

                            <Label Text="Últimas Transações"
                                   TextColor="White"
                                   FontSize="20"
                                   FontAttributes="Bold" />

                            <!-- IMPORTANTE -->
                            <!-- AQUI VOLTOU A LISTA -->
                            <CollectionView x:Name="ListaTransacoes"
                                            HeightRequest="450"
                                            VerticalScrollBarVisibility="Never">

                                <CollectionView.EmptyView>

                                    <Label Text="Ainda não existem movimentos."
                                           TextColor="#8091A7"
                                           HorizontalOptions="Center"
                                           Margin="0,30"
                                           FontSize="14" />

                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>

                                    <DataTemplate x:DataType="models:Transacao">

                                        <Border BackgroundColor="#1A2330"
                                                Padding="15"
                                                Margin="0,0,0,10"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 16">

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="14">

                                                <!-- ÍCONE -->
                                                <Frame Grid.Column="0"
                                                       HeightRequest="46"
                                                       WidthRequest="46"
                                                       CornerRadius="23"
                                                       Padding="0"
                                                       BackgroundColor="#2952D1"
                                                       BorderColor="Transparent"
                                                       VerticalOptions="Center">

                                                    <Label Text="💳"
                                                           FontSize="16"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />

                                                </Frame>

                                                <!-- INFO -->
                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="3"
                                                                     VerticalOptions="Center">

                                                    <Label Text="{Binding NomeTransacao}"
                                                           TextColor="White"
                                                           FontSize="14"
                                                           FontAttributes="Bold" />

                                                    <Label Text="{Binding DataTransacao, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                                           TextColor="#8FA1B8"
                                                           FontSize="12" />

                                                </VerticalStackLayout>

                                                <!-- VALOR -->
                                                <VerticalStackLayout Grid.Column="2"
                                                                     Spacing="2"
                                                                     HorizontalOptions="End"
                                                                     VerticalOptions="Center">

                                                    <Label Text="{Binding ValorTransacao, StringFormat='{0:C}'}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="End"
                                                           TextColor="{Binding CorValor}" />

                                                    <Label Text="{Binding TipoMovimento}"
                                                           FontSize="11"
                                                           TextColor="#7B8BA3"
                                                           HorizontalOptions="End" />

                                                </VerticalStackLayout>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </CollectionView.ItemTemplate>

                            </CollectionView>

                        </VerticalStackLayout>

                    </Border>

                </VerticalStackLayout>

                <!-- BOTÃO FLUTUANTE -->
                <Button Text="+"
                        Clicked="AoClicarNovaTransacao"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        FontSize="28"
                        FontAttributes="Bold"
                        HeightRequest="60"
                        WidthRequest="60"
                        CornerRadius="30"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Margin="0,0,10,10"
                        ZIndex="10"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Radius=10, Opacity=0.5}" />

            </Grid>

        </ScrollView>

    </Grid>

</ContentPage>