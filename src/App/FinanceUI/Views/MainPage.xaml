<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FinanceUI.Models" 
             x:Class="FinanceUI.MainPage"
             Title="O meu Saldo">

    <Grid>
        <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">

            <VerticalStackLayout Grid.Row="0" Spacing="15">

                <Frame BackgroundColor="#512BD4" CornerRadius="15" HasShadow="True" HeightRequest="120">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Saldo Total" TextColor="White" FontSize="16" HorizontalOptions="Center"/>
                        <Label x:Name="LblSaldoTotal" Text="0.00 €" TextColor="White" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="As minhas Contas" FontSize="18" FontAttributes="Bold" />
                <CollectionView x:Name="ListaContas" HeightRequest="110" ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Conta">
                            <Frame Margin="0,5,10,5" Padding="15" WidthRequest="160" BackgroundColor="White" BorderColor="#E0E0E0" CornerRadius="10">
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding NomeConta}" FontSize="12" TextColor="Gray" />
                                    <Label Text="{Binding MontanteFormatado}" FontSize="18" FontAttributes="Bold" TextColor="#512BD4" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <Frame Grid.Column="0" Padding="10" CornerRadius="10" BackgroundColor="#E8F5E9" BorderColor="Transparent">
                        <VerticalStackLayout>
                            <Label Text="Receitas" FontSize="12" TextColor="#2E7D32" HorizontalOptions="Center"/>
                            <Label x:Name="LblReceitas" Text="0.00 €" FontSize="16" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" Padding="10" CornerRadius="10" BackgroundColor="#FFEBEE" BorderColor="Transparent">
                        <VerticalStackLayout>
                            <Label Text="Despesas" FontSize="12" TextColor="#C62828" HorizontalOptions="Center"/>
                            <Label x:Name="LblDespesas" Text="0.00 €" FontSize="16" FontAttributes="Bold" TextColor="#C62828" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Label Text="Últimas Transações" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0" />
            </VerticalStackLayout>

            <CollectionView x:Name="ListaTransacoes" Grid.Row="1" Margin="0,5">
                <CollectionView.EmptyView>
                    <Label Text="Ainda não existem movimentos." HorizontalOptions="Center" Margin="0,50"/>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Transacao">
                        <Grid Padding="10" ColumnDefinitions="Auto, *, Auto">
                            <Frame Grid.Column="0" CornerRadius="20" HeightRequest="40" WidthRequest="40" 
                                   Padding="0" BackgroundColor="#F0F0F0" BorderColor="Transparent">
                                <Label Text="💰" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0">
                                <Label Text="{Binding NomeTransacao}" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding DataTransacao, StringFormat='{0:dd/MM/yyyy HH:mm}'}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="{Binding ValorTransacao, StringFormat='{0:C}'}" 
                                       FontAttributes="Bold" 
                                       TextColor="{Binding CorValor}"/>
                                <Label Text="{Binding TipoMovimento}" FontSize="10" TextColor="Gray" HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Button Text="+"
                Clicked="AoClicarNovaTransacao"
                BackgroundColor="#512BD4"
                TextColor="White"
                FontSize="24"
                FontAttributes="Bold"
                HeightRequest="60"
                WidthRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="25"
                Shadow="{Shadow Brush=Black, Offset='0,5', Radius=10, Opacity=0.3}" />
    </Grid>
</ContentPage>