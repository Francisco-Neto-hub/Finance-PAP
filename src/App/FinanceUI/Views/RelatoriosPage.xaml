<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FinanceUI.Models" 
             x:Class="FinanceUI.Views.RelatoriosPage"
             Title="Relatórios Detalhados"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="15">
            <Label Text="Filtrar Movimentos" FontSize="18" FontAttributes="Bold" TextColor="White" />

            <Frame BackgroundColor="#1E1E1E" BorderColor="#333" CornerRadius="12" Padding="15">
                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Mês" FontSize="12" TextColor="#A0A0A0" />
                            <Picker x:Name="PickerMes" TextColor="White" BackgroundColor="#2C2C2C" Title="Selecione o mês" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Ano" FontSize="12" TextColor="#A0A0A0" />
                            <Picker x:Name="PickerAno" TextColor="White" BackgroundColor="#2C2C2C" Title="Selecione o ano" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Conta" FontSize="12" TextColor="#A0A0A0" />
                        <Picker x:Name="PickerConta" 
                                Title="A carregar contas..." 
                                TextColor="White" 
                                BackgroundColor="#2C2C2C" 
                                ItemDisplayBinding="{Binding NomeConta}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Categoria" FontSize="12" TextColor="#A0A0A0" />
                        <Picker x:Name="PickerCategoria" 
                                Title="Todas as Categorias" 
                                TextColor="White" 
                                BackgroundColor="#2C2C2C" 
                                ItemDisplayBinding="{Binding Nome}" />
                    </VerticalStackLayout>

                    <SearchBar x:Name="SearchBarBusca" 
                               Placeholder="Pesquisar transação..." 
                               TextColor="White" 
                               BackgroundColor="#2C2C2C" 
                               CancelButtonColor="Red" />

                    <Button Text="Procurar Movimentos" 
                            Clicked="AoClicarProcurar" 
                            BackgroundColor="#512BD4" 
                            TextColor="White" 
                            CornerRadius="8" 
                            FontAttributes="Bold" 
                            HeightRequest="45" />

                    <ActivityIndicator x:Name="LoadingSpinner" IsRunning="False" IsVisible="False" Color="#AC94F4" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <Label x:Name="LblResumoPesquisa" Text="Resultados:" FontSize="16" FontAttributes="Bold" TextColor="White" IsVisible="False" Margin="0,10,0,0"/>
        </VerticalStackLayout>

        <CollectionView x:Name="ListaExtrato" Grid.Row="1" Margin="20,0,20,10">
            <CollectionView.EmptyView>
                <Label Text="Nenhum movimento encontrado para estes filtros." TextColor="Gray" HorizontalOptions="Center" Margin="0,30" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:RelatorioTransacaoDTO">
                    <Frame BackgroundColor="#1E1E1E" BorderColor="#333" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="5">

                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding NomeTransacao}" FontAttributes="Bold" FontSize="16" TextColor="White" />

                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding ValorTransacao, StringFormat='{0:C}'}" FontAttributes="Bold" FontSize="16" 
                                   TextColor="{Binding TipoMovimento, Converter={StaticResource CorValorConverter}}" />

                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="10">
                                <Label Text="{Binding DataTransacao, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="#888" />
                                <Label Text="•" TextColor="#555" />
                                <Label Text="{Binding Categoria}" FontSize="12" TextColor="#AC94F4" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="10">
                                <Frame BackgroundColor="#2C2C2C" CornerRadius="5" Padding="5,2" HasShadow="False">
                                    <Label Text="{Binding ContaDestino}" FontSize="10" TextColor="#A0A0A0" />
                                </Frame>
                                <Frame BackgroundColor="#2C2C2C" CornerRadius="5" Padding="5,2" HasShadow="False">
                                    <Label Text="{Binding TipoMovimento}" FontSize="10" TextColor="#A0A0A0" />
                                </Frame>
                            </HorizontalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>