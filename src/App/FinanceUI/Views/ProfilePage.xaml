<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.ProfilePage"
             Title="O Meu Perfil">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Dados Pessoais" FontAttributes="Bold" FontSize="18" TextColor="CornflowerBlue"/>

                    <VerticalStackLayout>
                        <Label Text="Nome Completo" FontSize="12" TextColor="Gray"/>
                        <Entry x:Name="NomeEntry" Placeholder="O teu nome" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Email" FontSize="12" TextColor="Gray"/>
                        <Entry x:Name="EmailEntry" Keyboard="Email" Placeholder="O teu email" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Telemóvel" FontSize="12" TextColor="Gray"/>
                        <Entry x:Name="TelemovelEntry" Keyboard="Telephone" Placeholder="O teu telemóvel" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Data de Nascimento" FontSize="12" TextColor="Gray"/>
                        <DatePicker x:Name="DataNascPicker" Format="yyyy-MM-dd" />
                    </VerticalStackLayout>

                    <Button Text="Guardar Alterações" 
                            Clicked="AoClicarGuardarPerfil" 
                            BackgroundColor="CornflowerBlue" 
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="45"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="LightGray" CornerRadius="10" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Segurança" FontAttributes="Bold" FontSize="18" TextColor="Orange"/>

                    <VerticalStackLayout>
                        <Label Text="Password Atual" FontSize="12" TextColor="Gray"/>
                        <Entry x:Name="AntigaPassEntry" IsPassword="True" Placeholder="Insere a password atual"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Nova Password" FontSize="12" TextColor="Gray"/>
                        <Entry x:Name="NovaPassEntry" IsPassword="True" Placeholder="Insere a nova password"/>
                    </VerticalStackLayout>

                    <Button Text="Mudar Password" 
                            Clicked="AoClicarMudarPass" 
                            BackgroundColor="Orange" 
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="45"
                            Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="LightGray" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Conta" FontAttributes="Bold" FontSize="18" />
                    <Button Text="Terminar Sessão" Clicked="AoClicarLogout" BackgroundColor="Red" />
                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator x:Name="Indicador" IsRunning="False" Color="CornflowerBlue" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>