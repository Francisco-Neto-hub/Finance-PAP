<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.ProfilePage"
             BackgroundColor="#0F1115">

    <ContentPage.Resources>
        <Style x:Key="ProfileInputBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>

        <Style x:Key="ProfileSectionBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#161618" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="Padding" Value="25" />
            <Setter Property="Margin" Value="0,0,0,25" />
        </Style>

        <Style x:Key="TogglePassButtonStyle" TargetType="ImageButton">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="WidthRequest" Value="40" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="*">

        <Grid Grid.Column="0" BackgroundColor="#070B10" />

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="30,25" Spacing="0">

                <VerticalStackLayout Spacing="2" Margin="0,0,0,30">
                    <Label Text="O Meu Perfil" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Gere as tuas informações e definições de segurança" FontSize="14" TextColor="#8E8E93"/>
                </VerticalStackLayout>

                <Label Text="DADOS PESSOAIS" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0,0,10"/>
                <Border Style="{StaticResource ProfileSectionBorder}">
                    <VerticalStackLayout Spacing="20">
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Nome Completo" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <Entry x:Name="NomeEntry" Placeholder="O teu nome" TextColor="White" PlaceholderColor="#48484A" BackgroundColor="Transparent" HeightRequest="50"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Endereço de Email" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <Entry x:Name="EmailEntry" Keyboard="Email" Placeholder="exemplo@email.com" TextColor="White" PlaceholderColor="#48484A" BackgroundColor="Transparent" HeightRequest="50"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Telemóvel" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <Entry x:Name="TelemovelEntry" Keyboard="Telephone" Placeholder="+351 9xx xxx xxx" TextColor="White" PlaceholderColor="#48484A" BackgroundColor="Transparent" HeightRequest="50"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Data de Nascimento" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <DatePicker x:Name="DataNascPicker" Format="dd/MM/yyyy" TextColor="White" HeightRequest="50"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Guardar Alterações" Clicked="AoClicarGuardarPerfil" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="48" HorizontalOptions="End" Padding="30,0"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="SEGURANÇA" FontSize="12" FontAttributes="Bold" TextColor="#F59E0B" Margin="5,0,0,10"/>
                <Border Style="{StaticResource ProfileSectionBorder}">
                    <VerticalStackLayout Spacing="20">

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">

                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Password Atual" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Entry x:Name="AntigaPassEntry" 
                                               IsPassword="True" 
                                               Placeholder="••••••••" 
                                               TextColor="White" 
                                               PlaceholderColor="#48484A" 
                                               BackgroundColor="Transparent" 
                                               HeightRequest="50"
                                               Grid.Column="0"/>
                                        <ImageButton x:Name="BtnToggleAntigaPass"
                                                     Grid.Column="1"
                                                     Source="olho_visivel.png"
                                                     Style="{StaticResource TogglePassButtonStyle}"
                                                     Clicked="AoClicarMostrarOcultarAntigaPassword"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Nova Password" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource ProfileInputBorder}">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Entry x:Name="NovaPassEntry" 
                                               IsPassword="True" 
                                               Placeholder="••••••••" 
                                               TextColor="White" 
                                               PlaceholderColor="#48484A" 
                                               BackgroundColor="Transparent" 
                                               HeightRequest="50"
                                               Grid.Column="0"/>
                                        <ImageButton x:Name="BtnToggleNovaPass"
                                                     Grid.Column="1"
                                                     Source="olho_visivel.png"
                                                     Style="{StaticResource TogglePassButtonStyle}"
                                                     Clicked="AoClicarMostrarOcultarNovaPassword"/>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                        </Grid>

                        <Button Text="Mudar Password" Clicked="AoClicarMudarPass" BackgroundColor="#F59E0B" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="48" HorizontalOptions="End" Padding="30,0"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="GESTÃO DA CONTA" FontSize="12" FontAttributes="Bold" TextColor="#EF4444" Margin="5,0,0,10"/>
                <Border Style="{StaticResource ProfileSectionBorder}" Stroke="#442727">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Terminar Sessão" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="Irá sair da sua conta neste dispositivo" FontSize="12" TextColor="#8E8E93"/>
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Sair da Conta" Clicked="AoClicarLogout" BackgroundColor="#EF4444" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="45" Padding="25,0"/>
                    </Grid>
                </Border>

                <ActivityIndicator x:Name="Indicador" IsRunning="False" Color="#2563EB" HorizontalOptions="Center" Margin="0,20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>