<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.HistoricoPage"
             BackgroundColor="#0F1115">

    <ContentPage.Resources>
        <Style x:Key="FilterBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#1C1C1E" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="*">

        <Grid Grid.Column="0" BackgroundColor="#070B10" />

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" Padding="30,25">

            <VerticalStackLayout Grid.Row="0" Spacing="2" Margin="0,0,0,20">
                <Label Text="Histórico de Transações" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Consulte e filtre os seus movimentos" FontSize="14" TextColor="#8E8E93"/>
            </VerticalStackLayout>

            <Border Grid.Row="1" 
                    Padding="20" 
                    Margin="0,0,0,20"
                    BackgroundColor="#161618"
                    Stroke="#2C2C2E"
                    StrokeShape="RoundRectangle 18">

                <VerticalStackLayout Spacing="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Selecionar Conta" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                        <Border Style="{StaticResource FilterBorder}">
                            <Picker x:Name="ContaPicker"
                                    Title="Todas as contas"
                                    TitleColor="#48484A"
                                    TextColor="White"
                                    ItemDisplayBinding="{Binding NomeConta}"
                                    SelectedIndexChanged="AoMudarConta"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="De" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                            <Border Style="{StaticResource FilterBorder}">
                                <DatePicker x:Name="DataInicioPicker" TextColor="White" Format="dd/MM/yyyy"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Até" FontSize="12" TextColor="#8E8E93" Margin="5,0"/>
                            <Border Style="{StaticResource FilterBorder}">
                                <DatePicker x:Name="DataFimPicker" TextColor="White" Format="dd/MM/yyyy"/>
                            </Border>
                        </VerticalStackLayout>

                        <Button Grid.Column="2"
                                Text="Filtrar"
                                VerticalOptions="End"
                                Clicked="AoClicarFiltrar"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="45"
                                Padding="25,0"
                                CornerRadius="10"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <RefreshView Grid.Row="2" 
                         x:Name="RefreshExtrato" 
                         Refreshing="AoAtualizarLista"
                         RefreshColor="#2563EB">

                <CollectionView x:Name="ListaTransacoes" 
                                SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Margin="0,50">
                            <Label Text="📭" FontSize="50" HorizontalTextAlignment="Center"/>
                            <Label Text="Sem movimentos neste período" FontSize="16" TextColor="#8E8E93" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16" 
                                    BackgroundColor="#1C1C1E"
                                    Stroke="#2C2C2E"
                                    StrokeShape="RoundRectangle 15">

                                <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="15">

                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label Text="{Binding DataTransacao, StringFormat='{0:dd}'}" 
                                               FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                        <Label Text="{Binding DataTransacao, StringFormat='{0:MMM}'}" 
                                               FontSize="11" TextColor="#8E8E93" HorizontalTextAlignment="Center" TextTransform="Uppercase"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding NomeTransacao}" FontSize="15" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Categoria}" FontSize="12" TextColor="#2563EB"/>
                                    </VerticalStackLayout>

                                    <HorizontalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Sinal}" FontSize="16" FontAttributes="Bold" TextColor="{Binding CorSinal}"/>
                                        <Label Text="{Binding ValorTransacao, StringFormat='{0:N2} €'}" FontSize="16" FontAttributes="Bold" TextColor="{Binding CorSinal}"/>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <ActivityIndicator Grid.Row="2"
                               x:Name="Indicador"
                               IsRunning="False"
                               Color="#2563EB"
                               VerticalOptions="Start" 
                               Margin="0,20,0,0"
                               HorizontalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>