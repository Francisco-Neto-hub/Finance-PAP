<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="FinanceUI.Views.GraficosPage"
             BackgroundColor="#0F1115">

    <ContentPage.Resources>
        <Style x:Key="FilterInputBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Padding" Value="12,2" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>

        <Style x:Key="ChartCardBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#161618" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,25" />
        </Style>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="*">

        <Grid Grid.Column="0" BackgroundColor="#070B10" />

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="30,25" Spacing="0">

                <VerticalStackLayout Spacing="2" Margin="0,0,0,25">
                    <Label Text="Análise de Desempenho" FontSize="28" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Visualize a saúde das suas finanças através de dados" FontSize="14" TextColor="#8E8E93"/>
                </VerticalStackLayout>

                <Border Padding="20" 
                        Margin="0,0,0,30"
                        BackgroundColor="#1C1C1E"
                        Stroke="#2C2C2E"
                        StrokeShape="RoundRectangle 18">

                    <VerticalStackLayout Spacing="15">
                        <Label Text="FILTRAR DADOS" FontSize="12" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>

                        <Grid ColumnDefinitions="*, *, 1.5*" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Mês" FontSize="11" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource FilterInputBorder}">
                                    <Picker x:Name="PickerMes" Title="Mês" TextColor="White" TitleColor="#48484A"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Ano" FontSize="11" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource FilterInputBorder}">
                                    <Picker x:Name="PickerAno" Title="Ano" TextColor="White" TitleColor="#48484A"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                <Label Text="Conta Específica" FontSize="11" TextColor="#8E8E93" Margin="5,0"/>
                                <Border Style="{StaticResource FilterInputBorder}">
                                    <Picker x:Name="PickerConta" 
                                            Title="Todas as Contas" 
                                            TextColor="White" 
                                            TitleColor="#48484A"
                                            ItemDisplayBinding="{Binding NomeConta}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="Auto, *">
                            <ActivityIndicator x:Name="LoadingSpinner" IsRunning="False" Color="#2563EB" VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                    Text="Atualizar Gráficos" 
                                    Clicked="AoClicarGerar" 
                                    BackgroundColor="#2563EB" 
                                    TextColor="White" 
                                    FontAttributes="Bold"
                                    HeightRequest="45"
                                    HorizontalOptions="End"
                                    Padding="30,0"
                                    CornerRadius="10" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Despesas por Categoria" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource ChartCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <micro:ChartView x:Name="ChartDonut" HeightRequest="280" BackgroundColor="Transparent"/>
                        <Label Text="* Dados baseados no mês selecionado" FontSize="11" TextColor="#48484A" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Evolução Mensal (Receitas vs Despesas)" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,12"/>
                <Border Style="{StaticResource ChartCardBorder}">
                    <VerticalStackLayout Spacing="10">
                        <micro:ChartView x:Name="ChartBarras" HeightRequest="320" BackgroundColor="Transparent"/>
                        <Label Text="* Comparativo anual de fluxo de caixa" FontSize="11" TextColor="#48484A" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>