<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.LoginPage"
             BackgroundColor="#0F1115">

    <!-- Grid garante que o conteúdo consegue ser perfeitamente centralizado na vertical -->
    <Grid VerticalOptions="FillAndExpand">
        <ScrollView VerticalOptions="Center">

            <VerticalStackLayout Spacing="18" Padding="30" HorizontalOptions="Center" MaximumWidthRequest="450">

                <!-- Título -->
                <Label Text="FINANCE"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="CornflowerBlue"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0" />

                <!-- Logótipo -->
                <Image Source="applogo.png" 
                        WidthRequest="120" 
                        HeightRequest="120" 
                        MinimumWidthRequest="120"
                        MinimumHeightRequest="120"
                        Aspect="AspectFit"
                        HorizontalOptions="Center"
                        Margin="0,10"/>

                <!-- Mensagem de Boas-vindas -->
                <Label Text="Bem-vindo à App! Faça login para continuar."
                       FontSize="16"
                       TextColor="#E0E0E0"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,0,0,15" />

                <!-- Campo Email -->
                <Frame Padding="5,0" CornerRadius="10" HasShadow="False" BorderColor="LightGray" BackgroundColor="#1E1E1E">
                    <Entry x:Name="EmailEntry" 
                           Placeholder="Email" 
                           PlaceholderColor="Gray"
                           TextColor="White"
                           Keyboard="Email"
                           HeightRequest="50" />
                </Frame>

                <!-- Campo Palavra-passe -->
                <Frame Padding="5,0" CornerRadius="10" HasShadow="False" BorderColor="LightGray" BackgroundColor="#1E1E1E">
                    <Grid ColumnDefinitions="*, Auto">

                        <!-- Input de Texto -->
                        <Entry x:Name="PassEntry" 
                                Grid.Column="0"
                                Placeholder="Palavra-passe" 
                                PlaceholderColor="Gray"
                                TextColor="White"
                                IsPassword="True"
                                HeightRequest="50"
                                VerticalOptions="Center" />

                        <!-- Botão com o ícone do Olho -->
                        <ImageButton x:Name="BtnTogglePassword"
                                Grid.Column="1"
                                Source="olho_visivel.png"
                                HeightRequest="24"
                                WidthRequest="24"
                                Margin="0,0,10,0"
                                VerticalOptions="Center"
                                BackgroundColor="Transparent"
                                Clicked="AoClicarMostrarOcultarPassword" />
                    </Grid>
                </Frame>

                <!-- Botão Entrar -->
                <Button x:Name="BtnLogin" 
                        Text="ENTRAR" 
                        Clicked="AoClicarEntrar" 
                        CornerRadius="10"
                        HeightRequest="52"
                        FontAttributes="Bold"
                        BackgroundColor="CornflowerBlue"
                        TextColor="White"
                        Margin="0,10,0,0" />

                <!-- Recuperar Password -->
                <Button Text="Esqueci-me da palavra-passe" 
                        Clicked="AoClicarEsqueciPassword" 
                        BackgroundColor="Transparent" 
                        TextColor="CornflowerBlue" 
                        FontSize="14" />

                <!-- Indicador de Carregamento -->
                <ActivityIndicator x:Name="Indicador" 
                                   IsRunning="False" 
                                   Color="CornflowerBlue"
                                   HorizontalOptions="Center" />

                <!-- Zona de Registo (Corrigida para ficar na mesma linha) -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                    <Label Text="Não tem conta?" TextColor="White" FontSize="14" />
                    <Label Text="Crie uma aqui" 
                           TextColor="CornflowerBlue" 
                           FontAttributes="Bold"
                           FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AoClicarCriarConta" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>