<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.LoginPage"
             BackgroundColor="#0F1115"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="LoginInputBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="HeightRequest" Value="55" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>
    </ContentPage.Resources>

    <Grid VerticalOptions="FillAndExpand">
        <ScrollView VerticalOptions="Center">

            <VerticalStackLayout Spacing="25" 
                                 Padding="40" 
                                 HorizontalOptions="Center" 
                                 MaximumWidthRequest="420"
                                 WidthRequest="420">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,20">
                    <Image Source="applogo.png" 
                           WidthRequest="100" 
                           HeightRequest="100" 
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />

                    <Label Text="FINANCE"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" 
                           CharacterSpacing="2"/>

                    <Label Text="Faça login para gerir as suas finanças"
                           FontSize="14"
                           TextColor="#8E8E93"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="EMAIL" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource LoginInputBorder}">
                        <Entry x:Name="EmailEntry" 
                               Placeholder="exemplo@email.com" 
                               PlaceholderColor="#48484A"
                               TextColor="White"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="PALAVRA-PASSE" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource LoginInputBorder}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="PassEntry" 
                                   Placeholder="Insira a sua password" 
                                   PlaceholderColor="#48484A"
                                   TextColor="White"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />

                            <ImageButton x:Name="BtnTogglePassword"
                                         Grid.Column="1"
                                         Source="olho_visivel.png"
                                         HeightRequest="24"
                                         WidthRequest="24"
                                         VerticalOptions="Center"
                                         BackgroundColor="Transparent"
                                         Clicked="AoClicarMostrarOcultarPassword" />
                        </Grid>
                    </Border>

                    <Label Text="Esqueceu-se da palavra-passe?" 
                           TextColor="#2563EB" 
                           FontSize="12" 
                           HorizontalOptions="End"
                           Margin="0,2,5,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AoClicarEsqueciPassword" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Margin="0,10,0,0">
                    <Button x:Name="BtnLogin" 
                            Text="ENTRAR NA CONTA" 
                            Clicked="AoClicarEntrar" 
                            CornerRadius="12"
                            HeightRequest="55"
                            FontAttributes="Bold"
                            BackgroundColor="#2563EB"
                            TextColor="White" />

                    <ActivityIndicator x:Name="Indicador" 
                                       IsRunning="False" 
                                       Color="#2563EB"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,20,0,0">
                    <Label Text="Ainda não tem conta?" TextColor="#8E8E93" FontSize="14" />
                    <Label Text="Crie uma aqui" 
                           TextColor="#2563EB" 
                           FontAttributes="Bold"
                           FontSize="14">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AoClicarCriarConta" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>