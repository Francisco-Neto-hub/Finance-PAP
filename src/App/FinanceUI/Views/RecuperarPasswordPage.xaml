<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.Views.RecuperarPasswordPage"
             BackgroundColor="#0F1115"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="RecoveryInputBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#2C2C2E" />
            <Setter Property="Background" Value="#111318" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="HeightRequest" Value="55" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>

        <Style x:Key="EyeButtonStyle" TargetType="ImageButton">
            <Setter Property="HeightRequest" Value="24" />
            <Setter Property="WidthRequest" Value="24" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
    </ContentPage.Resources>

    <Grid VerticalOptions="FillAndExpand">
        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Spacing="22" 
                                 Padding="40" 
                                 HorizontalOptions="Center" 
                                 MaximumWidthRequest="420"
                                 WidthRequest="420">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,10">
                    <Label Text="🔒" FontSize="50" HorizontalOptions="Center" Margin="0,0,0,10"/>
                    <Label Text="Recuperar Acesso"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Confirme os seus dados para definir uma nova password de segurança."
                           FontSize="14"
                           TextColor="#8E8E93"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="EMAIL DE REGISTO" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource RecoveryInputBorder}">
                        <Entry x:Name="EmailEntry" 
                               Placeholder="exemplo@email.com" 
                               PlaceholderColor="#48484A"
                               TextColor="White"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="TELEMÓVEL" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource RecoveryInputBorder}">
                        <Entry x:Name="TelemovelEntry" 
                               Placeholder="+351 9xx xxx xxx" 
                               PlaceholderColor="#48484A"
                               TextColor="White"
                               Keyboard="Telephone"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center" />
                    </Border>
                </VerticalStackLayout>

                <BoxView Color="#1A1A1C" HeightRequest="1" Margin="0,10" />

                <VerticalStackLayout Spacing="8">
                    <Label Text="NOVA PASSWORD" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource RecoveryInputBorder}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="NovaPassEntry" 
                                   Placeholder="Mínimo 8 caracteres" 
                                   PlaceholderColor="#48484A"
                                   TextColor="White"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                            <ImageButton x:Name="BtnToggleNovaPass"
                                         Grid.Column="1"
                                         Source="olho_visivel.png"
                                         Style="{StaticResource EyeButtonStyle}"
                                         Clicked="AoClicarMostrarOcultarNovaPass" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="CONFIRMAR NOVA PASSWORD" FontSize="11" FontAttributes="Bold" TextColor="#2563EB" Margin="5,0"/>
                    <Border Style="{StaticResource RecoveryInputBorder}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Entry x:Name="ConfirmarPassEntry" 
                                   Placeholder="Repita a password" 
                                   PlaceholderColor="#48484A"
                                   TextColor="White"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                            <ImageButton x:Name="BtnToggleConfirmPass"
                                         Grid.Column="1"
                                         Source="olho_visivel.png"
                                         Style="{StaticResource EyeButtonStyle}"
                                         Clicked="AoClicarMostrarOcultarConfirmPass" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Margin="0,15,0,0">
                    <Button x:Name="BtnRecuperar" 
                            Text="REDEFINIR PASSWORD" 
                            Clicked="AoClicarRecuperar" 
                            BackgroundColor="#2563EB" 
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="55" />

                    <ActivityIndicator x:Name="Indicador" 
                                       IsRunning="False" 
                                       Color="#2563EB"
                                       HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Label Text="Voltar ao Login" 
                       TextColor="#8E8E93" 
                       FontSize="14" 
                       HorizontalOptions="Center"
                       Margin="0,10,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="AoClicarVoltarLogin" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>