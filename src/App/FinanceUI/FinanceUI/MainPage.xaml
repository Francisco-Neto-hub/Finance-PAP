<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceUI.MainPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border StrokeShape="RoundRectangle 20" BackgroundColor="#2B3A67" Padding="20" HeightRequest="150">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Saldo Geral" TextColor="White" HorizontalOptions="Center" Opacity="0.7"/>
                    <Label x:Name="lblSaldo" Text="€ 0,00" TextColor="White" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Ações Rápidas" FontAttributes="Bold" FontSize="18"/>
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Transf." BackgroundColor="#EEF2FF" TextColor="#2B3A67" HeightRequest="80"/>
                <Button Grid.Column="1" Text="Receitas" BackgroundColor="#ECFDF5" TextColor="#065F46" HeightRequest="80"/>
                <Button Grid.Column="2" Text="Despesas" BackgroundColor="#FEF2F2" TextColor="#991B1B" HeightRequest="80"/>
            </Grid>

            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                <Label Text="Minhas Contas" FontAttributes="Bold" FontSize="18"/>
            </HorizontalStackLayout>

            <CollectionView x:Name="cvContas">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5" Padding="15" CornerRadius="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding NomeConta}" FontAttributes="Bold" FontSize="16"/>
                                    <Label Text="{Binding Titular}" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding SaldoAtual, StringFormat='{0:C}'}" 
                                       FontAttributes="Bold" VerticalOptions="Center" TextColor="#2B3A67"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>